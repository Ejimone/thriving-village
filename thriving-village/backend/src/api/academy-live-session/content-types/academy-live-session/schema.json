      "target": "api::academy-cohort.academy-cohort",
      "inversedBy": "sessions",
      "required": true
    },
    "title": {
      "type": "string",
      "required": true
    },
    "type": {
      "type": "enumeration",
      "enum": ["Live call", "Workshop"],
      "required": true
    },
    "day": {
      "type": "string",
      "required": true
    },
    "time": {
      "type": "string",
      "required": true
    },
    "host": {
      "type": "string",
      "required": true
    },
    "link": {
      "type": "string"
    }
  }
}
